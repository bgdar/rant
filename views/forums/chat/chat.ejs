<div
  class="flex h-screen bg-[#0f0f0f] text-white"
  x-data="chatApp({
    forum: <%= JSON.stringify(forum) %>,
    initialChats: <%= JSON.stringify(chats) %>,
    currentUser: <%= JSON.stringify(currentUser) %>
  })"
  x-init="init()"
>
  <aside class="w-[280px] bg-black border-r border-neutral-800 flex flex-col">
    <div class="p-5 border-b border-neutral-800">
      <h1 class="text-xl font-black truncate" x-text="forum.name"></h1>
      <p class="text-neutral-500 text-sm mt-1">Live discussion room</p>
    </div>

    <div class="p-5 space-y-3">
      <div class="text-sm text-neutral-500 font-bold tracking-wider">STATUS</div>
      <div class="flex items-center gap-2">
        <div
          class="w-2 h-2 rounded-full"
          :class="status === 'Online' ? 'bg-green-500' : 'bg-red-500'"
        ></div>
        <span class="text-sm font-medium" x-text="status"></span>
      </div>

      <div class="text-sm text-neutral-500 font-bold tracking-wider mt-5">MEMBERS</div>
      <div class="text-white text-sm">
        <span class="font-bold text-neutral-200" x-text="forum.totalMembers || 0"></span> registered
      </div>
    </div>
  </aside>
  <main class="flex flex-col flex-1 min-w-0">
    <header class="h-16 bg-[#111111] border-b border-neutral-800 flex items-center px-5">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-neutral-800 flex items-center justify-center font-bold text-sm uppercase border border-neutral-700">
          <span x-text="forum.name.substring(0, 2)"></span>
        </div>

        <div>
          <h2 class="font-bold text-sm" x-text="forum.name"></h2>
          <p class="text-xs text-neutral-500">
            #<span x-text="forum.slug"></span>
          </p>
        </div>
      </div>
    </header>

    <div
      class="flex-1 overflow-y-auto p-5 space-y-3 bg-[#0f0f0f]"
      x-ref="chatBox"
    >
      <template x-for="(msg, i) in messages" :key="i">
        <div class="flex flex-col" :class="isMyChat(msg) ? 'items-end' : 'items-start'">
          <!-- Nama Pengirim (Hanya jika dikirim orang lain) -->
          <template x-if="!isMyChat(msg)">
            <span class="text-[11px] font-bold text-neutral-500 mb-1 ml-1" x-text="msg.senderId"></span>
          </template>

          <div
            class="max-w-[70%] px-4 py-2.5 rounded-2xl text-sm shadow-sm break-words"
            :class="isMyChat(msg)
              ? 'bg-neutral-900 text-white rounded-br-none border border-neutral-800'
              : 'bg-[#1a1a1a] text-white rounded-bl-none border border-neutral-800'"
          >
            <div x-text="msg.message"></div>

            <div class="text-[9px] text-neutral-500 mt-1 text-right select-none">
              <span x-text="formatTime(msg.createdAt)"></span>
            </div>
          </div>
        </div>
      </template>
    </div>

    <!-- INPUT BAR CHAT -->
    <div class="p-4 bg-[#111111] border-t border-neutral-800 flex gap-2">
      <input
        x-model="newMessage"
        @keydown.enter="sendMessage()"
        placeholder="Type message..."
        class="flex-1 px-4 py-3 rounded-2xl bg-black border border-neutral-800 text-white outline-none focus:border-neutral-700 text-sm transition"
      />

      <button
        @click="sendMessage()"
        :disabled="!newMessage.trim()"
        class="bg-white hover:bg-neutral-200 disabled:bg-neutral-900 disabled:text-neutral-700 text-black px-5 rounded-2xl font-bold text-sm transition cursor-pointer"
      >
        Send
      </button>
    </div>
  </main>
</div>

<script>
  function chatApp(serverData) {
    return {
      socket: null,
      status: 'Connecting...',
      newMessage: '',
      
      // Inject data asli dari controller
      forum: serverData.forum || {},
      currentUser: serverData.currentUser || {},
      messages: serverData.initialChats || [],

      init() {
        const serverUrl = window.location.hostname + ':3051';

        this.socket = io(serverUrl, {
          transports: ['websocket'],
        });

        // CONNECT & JOIN
        this.socket.on('connect', () => {
          this.status = 'Online';

          // Emit joinRoom menggunakan _id asli database forum
          this.socket.emit('joinRoom', {
            forumId: this.forum._id || this.forum.id,
          });
        });

        // RECEIVE MESSAGE: Menangkap payload asli ChatDTO dari gateway/server
        this.socket.on('message', (data) => {
          // Mencegah double push jika websocket mengirim balik pesan kita sendiri
          if (data.senderId === (this.currentUser.id || this.currentUser._id)) return;

          this.messages.push(data);
          this.scrollBottom();
        });

        // STATUS HANDLER
        this.socket.on('disconnect', () => {
          this.status = 'Offline';
        });

        this.socket.on('exception', (err) => {
          console.error('Socket Error:', err);
        });

        // Langsung scroll ke bawah setelah history chats bawaan ter-render
        this.scrollBottom();
      },

      // Fungsi pencocokan status pengirim chat
      isMyChat(msg) {
        if (!this.currentUser) return false;
        return msg.senderId === (this.currentUser.id || this.currentUser._id);
      },

      sendMessage() {
        if (!this.newMessage.trim()) return;

        // Sesuaikan Payload 100% dengan kebutuhan ChatDTO di server
        const payload = {
          forumId: this.forum._id || this.forum.id,
          senderId: this.currentUser.id || this.currentUser._id || 'Unknown',
          message: this.newMessage.trim(),
          type: 'text', // Mengikuti ChatType enum
          isEdited: false,
          isDeleted: false,
          readBy: [],
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };

        // Kirim struktur data lengkap ke server Gateway
        this.socket.emit('message', payload);

        // Push ke UI lokal secara reaktif
        this.messages.push(payload);
        this.newMessage = '';
        this.scrollBottom();
      },

      scrollBottom() {
        this.$nextTick(() => {
          const el = this.$refs.chatBox;
          if (el) el.scrollTop = el.scrollHeight;
        });
      },

      formatTime(dateStr) {
        if (!dateStr) return '';
        return new Date(dateStr).toLocaleTimeString([], {
          hour: '2-digit',
          minute: '2-digit',
        });
      },
    };
  }
</script>

<script>
  window.GROUP_CHAT_DATA = {
    title: "<%= title || 'Group Chat' %>",
    forum: <%- JSON.stringify(forum || {}) %>,
    currentUser: <%- JSON.stringify(currentUser || {}) %>,
    initialChats: <%- JSON.stringify(chats || []) %>
  };
  console.log("=== DATA GRUP DARI SERVER ===", window.GROUP_CHAT_DATA);
</script>

<div 
class="flex h-screen   bg-[#0f0f0f] text-white-primary font-sans antialiased overflow-hidden" 
x-data="groupChatApp(window.GROUP_CHAT_DATA)" 
x-init="init()"
>


<main class="flex flex-col flex-1 w-full relative">
  
  
  <%- include('../../components/navbar',{responsivNav : 'left'}) %>
  
  
  <header class="bg-black-secondary border-b border-neutral-800 px-4 py-3 flex items-center justify-between shrink-0 z-10 shadow-sm">
      <div class="flex items-center gap-3">
        <a href="/forums/search" class="text-gray-primary hover:text-main-primary transition-colors mr-1 md:hidden">
          <i class="fas fa-arrow-left text-lg"></i>
        </a>
        
        <div class="w-10 h-10 rounded-full bg-neutral-800 border border-neutral-700 flex items-center justify-center overflow-hidden shrink-0">
          <template x-if="forum.image">
            <img :src="forum.image" alt="Group" class="w-full h-full object-cover">
          </template>
          <template x-if="!forum.image">
            <span class="font-bold text-sm uppercase" x-text="(forum.name || 'GR').substring(0, 2)"></span>
          </template>
        </div>
        
        <div>
          <h1 class="font-bold text-base md:text-lg text-white-primary leading-tight flex items-center gap-2">
            <span x-text="forum.name || 'Unknown Group'"></span>
          </h1>
          <p class="text-3xs md:text-2xs flex items-center mt-0.5" :class="isConnected ? 'text-green-500' : 'text-amber-500'">
            <span class="w-1.5 h-1.5 rounded-full mr-1.5" :class="isConnected ? 'bg-green-500 animate-pulse' : 'bg-amber-500'"></span>
            <span x-text="isConnected ? 'Live Chat Aktif' : 'Menghubungkan...'"></span>
          </p>
        </div>
      </div>
    </header>



    <div 
      class="flex-1 overflow-y-auto p-4 w-full scroll-smooth" 
      x-ref="messageContainer"
      style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png'); background-blend-mode: overlay; background-color: #0a0a0a;"
    >
      <div class="max-w-4xl mx-auto space-y-4 flex flex-col justify-end min-h-full pb-2">
        
        <div x-show="messages.length === 0" class="text-center text-gray-secondary my-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-neutral-900 mb-3">
            <i class="fas fa-comments text-2xl text-main-primary opacity-80"></i>
          </div>
          <p class="text-sm">Belum ada obrolan di grup ini.</p>
        </div>

        <template x-for="(msg, index) in messages" :key="msg._id || index">
          <div class="flex flex-col" :class="isMyMessage(msg.senderId) ? 'items-end' : 'items-start'">
            
            <span 
              x-show="!isMyMessage(msg.senderId)" 
              class="text-3xs ml-12 mb-1 font-semibold tracking-wide flex items-center gap-1"
              :class="msg.isAi ? 'text-main-accent' : 'text-gray-primary'"
            >
              <i x-show="msg.isAi" class="fas fa-robot"></i>
              <span x-text="msg.isAi ? 'AI Assistant' : (msg.senderName || 'Member')"></span>
            </span>

            <div class="flex items-end gap-2 max-w-[85%] md:max-w-[70%]">
              
              <div x-show="!isMyMessage(msg.senderId)" class="w-8 h-8 rounded-full border border-neutral-700 flex items-center justify-center shrink-0 overflow-hidden mb-1" :class="msg.isAi ? 'bg-main-primary text-white' : 'bg-neutral-800 text-gray-300'">
                <template x-if="msg.isAi">
                  <i class="fas fa-bolt text-xs"></i>
                </template>
                <template x-if="!msg.isAi">
                  <span class="text-3xs font-bold uppercase" x-text="(msg.senderName || 'U').substring(0, 2)"></span>
                </template>
              </div>

              <div 
                class="px-4 py-2.5 rounded-2xl relative shadow-sm text-sm"
                :class="isMyMessage(msg.senderId) 
                  ? 'bg-main-primary text-white-primary rounded-br-sm' 
                  : (msg.isAi ? 'bg-neutral-900 border border-main-primary text-gray-100 rounded-bl-sm' : 'bg-neutral-800 border border-neutral-700 text-gray-100 rounded-bl-sm')"
              >
                <div x-show="msg.isToxic" class="text-[9px] text-red-400 font-bold mb-1 uppercase tracking-wider">
                  <i class="fas fa-exclamation-triangle"></i> Pesan disensor/Toksik
                </div>

                <div class="break-words whitespace-pre-wrap leading-relaxed" x-text="msg.message || msg.content"></div>
                
                <div 
                  class="text-[10px] text-right mt-1.5 opacity-70 flex items-center justify-end gap-1"
                  :class="isMyMessage(msg.senderId) ? 'text-white' : 'text-gray-400'"
                >
                  <span x-text="formatTime(msg.createdAt)"></span>
                </div>
              </div>
            </div>

          </div>
        </template>
      </div>
    </div>

    <footer class="bg-black-secondary border-t border-neutral-800 p-3 md:p-4 shrink-0">
      <form @submit.prevent="sendMessage" class="max-w-4xl mx-auto flex items-end gap-2 bg-neutral-900 border border-neutral-700 rounded-xl p-1.5 shadow-inner">
        <input 
          type="text" 
          x-model="newMessage"
          placeholder="Ketik pesan ke grup..." 
          class="flex-1 bg-transparent text-white-primary placeholder-gray-500 py-3 px-3 focus:outline-none text-sm md:text-base"
          autocomplete="off"
        >
        <button 
          type="submit" 
          :disabled="newMessage.trim() === ''"
          class="w-11 h-11 rounded-full flex items-center justify-center shrink-0 transition-all duration-200"
          :class="newMessage.trim() !== '' ? 'bg-main-primary text-white-primary shadow-md hover:bg-main-accent' : 'bg-neutral-800 text-gray-600 cursor-not-allowed'"
        >
          <i class="fas fa-paper-plane" :class="newMessage.trim() !== '' ? 'ml-0.5' : ''"></i>
        </button>
      </form>
    </footer>

  </main>
</div>

<script>
function groupChatApp(serverData) {
  return {
    socketConnection: null,
    isConnected: false,
    
    // State Data
    forum: serverData.forum || {},
    currentUser: serverData.currentUser || {},
    messages: serverData.initialChats || [],
    
    // UI State
    newMessage: '',

    init() {
      // Setup koneksi Socket.io (mendukung port 3051)
      if (typeof io !== 'undefined') {
        this.socketConnection = io(window.location.hostname + ':3051', {
          transports: ['websocket']
        });
        this.setupSocketListeners();
      } else {
        console.error("Library Socket.io tidak ditemukan!");
      }

      this.scrollToBottom();
    },

    setupSocketListeners() {
      this.socketConnection.on('connect', () => {
        this.isConnected = true;
        console.log('[Group Chat] Terhubung ke Gateway Socket');
        
        // Meminta masuk ke room begitu koneksi stabil (Sesuai Gateway)
        this.socketConnection.emit('joinGrubRoom', { forumId: this.forum._id });
      });

      this.socketConnection.on('disconnect', () => {
        this.isConnected = false;
      });

      // Menangkap balasan berhasil join dari server
      this.socketConnection.on('joinGrubRoom', (data) => {
        console.log(`[Group Chat] Status Join:`, data.message);
      });

      // Menerima pesan grup dari anggota lain (Sesuai Gateway)
  this.socketConnection.on('grubMessage', (payload) => {
        const myId = this.currentUser.id || this.currentUser._id;
        
        // Jaga-jaga jika backend me-return senderId sebagai objek hasil populate (.populate('senderId'))
        const incomingSenderId = typeof payload.senderId === 'object' 
          ? (payload.senderId._id || payload.senderId.id) 
          : payload.senderId;

        // Gunakan String() untuk menyamakan tipe data dari MongoDB dan Frontend
        if (String(incomingSenderId) !== String(myId)) {
          this.messages.push(payload);
          this.scrollToBottom();
        }
        
        // Beritahu server bahwa pesan sudah dibaca
        this.socketConnection.emit('readGroupMessage', { 
          forumId: this.forum._id, 
          userId: myId 
        });
      });

      // Menerima hasil Prediksi AI dari RabbitMQ (Sesuai Gateway)
      this.socketConnection.on('resultGroupPredik', (result) => {
        if (result && result.response) {
          const aiReply = {
            _id: 'ai-' + Date.now(),
            message: result.response,
            senderId: 'ai-bot',
            senderName: 'AI Bot',
            isAi: true, // penanda bot untuk UI
            createdAt: new Date().toISOString(),
            isToxic: result.is_toxic || false
          };
          
          this.messages.push(aiReply);
          this.scrollToBottom();
        }
      });
    },

    sendMessage() {
      if (this.newMessage.trim() === '') return;
      const textMessage = this.newMessage.trim();
      const myId = this.currentUser.id || this.currentUser._id;
      const tempId = Date.now();

      // 1. Buat payload berdasarkan struktur DTO Gateway Anda
      const payload = {
        forumId: this.forum._id,
        senderId: myId,
        senderName: this.currentUser.username || 'Saya',
        message: textMessage,
        type: 'text',
        createdAt: new Date().toISOString()
      };

      // 2. Tampilkan pesan ke UI diri sendiri (Optimistic UI)
      this.messages.push(payload);
      this.scrollToBottom();

      // 3. Kirim ke Backend Socket (Sesuai Gateway)
      if (this.socketConnection) {
        // Event Chat Biasa
        this.socketConnection.emit('grubMessage', payload);

        // Event Trigger AI Prediksi
        this.socketConnection.emit('sendGroupPredik', {
          forumId: this.forum._id,
          user: this.currentUser.username || 'Member',
          isTyping: false,
          message: textMessage,
          user_id: tempId // Digunakan sebagai chatId untuk antrean rabbit
        });
      }

      // Bersihkan kolom input
      this.newMessage = '';
    },

   isMyMessage(senderId) {
      if (!senderId) return false;
      const myId = this.currentUser.id || this.currentUser._id;
      
      // Jaga-jaga jika senderId berupa objek saat data pertama kali di-load dari EJS
      const idToCheck = typeof senderId === 'object' 
        ? (senderId._id || senderId.id) 
        : senderId;
        
      // Bandingkan sebagai String yang mutlak
      return String(idToCheck) === String(myId);
    },

    scrollToBottom() {
      this.$nextTick(() => {
        const container = this.$refs.messageContainer;
        if (container) {
          // Scroll halus ke bawah
          container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' });
        }
      });
    },

    formatTime(dateString) {
      if (!dateString) return '';
      const date = new Date(dateString);
      return date.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    }
  }
}
</script>

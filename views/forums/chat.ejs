
<div
  class="flex h-screen bg-[#0f0f0f] text-white"
  x-data="chatApp()"
  x-init="init()"
>
  <aside class="w-[280px] bg-black border-r border-neutral-800 flex flex-col">
    <div class="p-5 border-b border-neutral-800">
      <h1 class="text-xl font-black" x-text="forum.name"></h1>
      <p class="text-[#999999] text-sm mt-1">
        Live discussion room
      </p>
    </div>

    <div class="p-5 space-y-3">
      <div class="text-sm text-[#999999]">STATUS</div>

      <div class="flex items-center gap-2">
        <div
          class="w-2 h-2 rounded-full"
          :class="status === 'Online' ? 'bg-green-500' : 'bg-red-500'"
        ></div>

        <span x-text="status"></span>
      </div>

      <div class="text-sm text-[#999999] mt-5">
        MEMBERS
      </div>

      <div class="text-white text-sm">
        <span x-text="members"></span> online
      </div>
    </div>
  </aside>

  <!-- CHAT AREA -->
  <main class="flex flex-col flex-1">
    <!-- HEADER -->
    <header class="h-16 bg-[#111111] border-b border-neutral-800 flex items-center px-5">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-[#ff0000] flex items-center justify-center font-bold">
          R
        </div>

        <div>
          <h2 class="font-bold" x-text="forum.name"></h2>
          <p class="text-xs text-[#999999]"># <span x-text="forum.slug"></span></p>
        </div>
      </div>
    </header>

    <!-- MESSAGES -->
    <div
      class="flex-1 overflow-y-auto p-5 space-y-3 bg-[#0f0f0f]"
      x-ref="chatBox"
    >
      <template x-for="(msg, i) in messages" :key="i">
        <div
          class="flex"
          :class="msg.sent ? 'justify-end' : 'justify-start'"
        >
          <div
            class="max-w-[70%] px-4 py-2 rounded-2xl text-sm shadow"
            :class="msg.sent
              ? 'bg-[#ff0000] text-white rounded-br-md'
              : 'bg-[#1a1a1a] text-white rounded-bl-md border border-neutral-800'"
          >
            <div x-text="msg.text"></div>

            <div class="text-[10px] text-[#999999] mt-1 text-right">
              <span x-text="msg.time"></span>
            </div>
          </div>
        </div>
      </template>
    </div>

    <!-- INPUT -->
    <div class="p-4 bg-[#111111] border-t border-neutral-800 flex gap-2">
      <input
        x-model="newMessage"
        @keydown.enter="sendMessage()"
        placeholder="Type message..."
        class="flex-1 px-4 py-3 rounded-2xl bg-black border border-neutral-800 text-white outline-none focus:border-[#ff0000]"
      />

      <button
        @click="sendMessage()"
        class="bg-[#ff0000] hover:opacity-90 transition px-5 rounded-2xl font-bold"
      >
        Send
      </button>
    </div>
  </main>
</div>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>

<script>
  function chatApp() {
    return {
      socket: null,

      status: 'Connecting...',

      newMessage: '',

      members: 0,

      forum: {
        id: '123',
        name: 'Loading...',
        slug: 'room',
      },

      messages: [],

      init() {
        const serverUrl =
          window.location.hostname + ':3051';

        this.socket = io(serverUrl, {
          transports: ['websocket'],
        });

        // CONNECT
        this.socket.on('connect', () => {
          this.status = 'Online';

          // JOIN ROOM (penting untuk forum)
          this.socket.emit('joinRoom', {
            forumId: this.forum.id,
          });
        });

        // RECEIVE MESSAGE
        this.socket.on('message', (data) => {
          this.messages.push({
            text: data.message,
            sent: false,
            time: this.getTime(),
          });

          this.scrollBottom();
        });

        // STATUS
        this.socket.on('disconnect', () => {
          this.status = 'Offline';
        });

        // ERROR
        this.socket.on('exception', (err) => {
          console.error(err);
        });
      },

      sendMessage() {
        if (!this.newMessage.trim()) return;

        const payload = {
          forumId: this.forum.id,
          message: this.newMessage,
        };

        // SEND TO SERVER
        this.socket.emit('message', payload);

        // PUSH UI
        this.messages.push({
          text: this.newMessage,
          sent: true,
          time: this.getTime(),
        });

        this.newMessage = '';

        this.scrollBottom();
      },

      scrollBottom() {
        this.$nextTick(() => {
          const el = this.$refs.chatBox;
          el.scrollTop = el.scrollHeight;
        });
      },

      getTime() {
        return new Date().toLocaleTimeString([], {
          hour: '2-digit',
          minute: '2-digit',
        });
      },
    };
  }
</script>

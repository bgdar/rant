        </div>
        <i class="fas fa-chevron-right text-xs text-gray-secondary"></i>
      </a>
    </div>
    <div
      class="bg-black-secondary text-white-secondary p-4 rounded-lg space-y-2"
    >
      <div
        class="flex items-center space-x-2 text-main-accent text-xs font-bold uppercase tracking-wider"
      >
        <i class="fas fa-exclamation-triangle"></i>
        <span>Tugas Supervisor</span>
      </div>
      <p class="text-xs text-gray-muted leading-relaxed">
        Terdapat <strong>5 laporan operator</strong> yang belum Anda verifikasi
        untuk penutupan buku kerja minggu ini.
      </p>
      <a
        href="#"
        class="inline-block text-[11px] font-bold text-white-primary underline hover:text-main-accent"
        >Selesaikan Sekarang &rarr;</a
      >
    </div>
  </div>
</div>

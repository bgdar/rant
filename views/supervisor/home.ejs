<div
  class="bg-white-secondary text-black-primary font-sans antialiased min-h-screen flex flex-col justify-between"
  x-data="{ sidebarOpen: false, activeTab: 'overview' }"
>
  <header
    class="bg-black-primary text-white-primary shadow-md px-6 py-4 flex justify-between items-center sticky top-0 z-50"
  >
    <div class="flex items-center space-x-4">
      <!-- Mobile Menu Button -->
      <button
        @click="sidebarOpen = !sidebarOpen"
        class="text-white-primary hover:text-main-accent focus:outline-none md:hidden"
      >
        <i class="fas fa-bars text-xl"></i>
      </button>
      <div class="flex items-center space-x-3">
        <div class="bg-main-primary text-white-primary p-2 rounded-lg">
          <i class="fas fa-chart-pie text-xl"></i>
        </div>
        <div>
          <h1 class="text-lg font-bold tracking-wide">Supervisor Panel</h1>
          <p class="text-xs text-gray-accent hidden sm:block">
            Sistem Monitoring & Manajemen
          </p>
        </div>
      </div>
    </div>

    <div class="flex items-center space-x-4">
      <div class="relative" x-data="{ openNotification: false }">
        <button
          @click="openNotification = !openNotification"
          class="text-gray-accent hover:text-white-primary relative p-2 focus:outline-none"
        >
          <i class="fas fa-bell text-lg"></i>
          <span
            class="absolute top-1 right-1 w-2 h-2 bg-main-primary rounded-full"
          ></span>
        </button>
        <!-- Dropdown Notifikasi -->
        <div
          x-show="openNotification"
          @click.away="openNotification = false"
          class="absolute right-0 mt-2 w-64 bg-white-primary border border-white-accent rounded-lg shadow-xl overflow-hidden z-50"
          style="display: none"
        >
          <div
            class="bg-black-secondary text-white-primary p-3 text-xs font-bold"
          >
            Notifikasi Terbaru
          </div>
          <div class="p-2 divide-y divide-white-accent text-xs">
            <a
              href="#"
              class="block p-2 hover:bg-white-secondary text-black-secondary"
              >User <strong>johndoe123</strong> berhasil dibuat.</a
            >
            <a
              href="#"
              class="block p-2 hover:bg-white-secondary text-black-secondary"
              >Laporan mingguan siap diunduh.</a
            >
          </div>
        </div>
      </div>

      <span class="text-sm text-white-secondary hidden md:inline"
        >Halo, <strong>Supervisor</strong></span
      >
      <div
        class="w-10 h-10 rounded-full bg-main-secondary flex items-center justify-center text-white-primary font-bold border-2 border-main-accent"
      >
        SP
      </div>
    </div>
  </header>

  <div class="flex grow">
    <!-- SIDEBAR NAVIGATION -->
    <aside
      :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
      class="fixed md:static inset-y-0 left-0 w-64 bg-black-secondary text-white-secondary p-4 space-y-6 transform md:translate-x-0 transition-transform duration-200 ease-in-out z-40 flex flex-col justify-between border-r border-black-accent"
    >
      <div class="space-y-4">
        <div
          class="text-xs font-bold tracking-wider text-gray-primary uppercase px-3"
        >
          Menu Utama
        </div>
        <nav class="space-y-1">
          <button
            @click.prevent="activeTab = 'overview'; sidebarOpen = false"
            :class="activeTab === 'overview' ? 'bg-main-primary text-white-primary' : 'hover:bg-black-accent text-gray-accent hover:text-white-primary'"
            class="flex items-center space-x-3 px-3 py-2.5 rounded-lg transition duration-200"
          >
            <i class="fas fa-home w-5"></i> <span>Overview</span>
          </button>

          <a
            href="/supervisor/user/create"
            @click.prevent="activeTab = 'create-user'; sidebarOpen = false"
            :class="activeTab === 'create-user' ? 'bg-main-primary text-white-primary' : 'hover:bg-black-accent text-gray-accent hover:text-white-primary'"
            class="flex items-center space-x-3 px-3 py-2.5 rounded-lg transition duration-200"
          >
            <i class="fas fa-user-plus w-5"></i> <span>Create New User</span>
          </a>

          <button
            @click.prevent="activeTab = 'users'; sidebarOpen = false"
            :class="activeTab === 'users' ? 'bg-main-primary text-white-primary' : 'hover:bg-black-accent text-gray-accent hover:text-white-primary'"
            class="flex items-center space-x-3 px-3 py-2.5 rounded-lg transition duration-200"
          >
            <i class="fas fa-users w-5"></i> <span>Data Pengguna</span>
          </button>

          <button
            @click.prevent="activeTab = 'logs'; sidebarOpen = false"
            :class="activeTab === 'logs' ? 'bg-main-primary text-white-primary' : 'hover:bg-black-accent text-gray-accent hover:text-white-primary'"
            class="flex items-center space-x-3 px-3 py-2.5 rounded-lg transition duration-200"
          >
            <i class="fas fa-history w-5"></i> <span>Log Aktivitas</span>
          </button>
        </nav>
      </div>

      <div>
        <button
          class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg bg-black-accent hover:bg-main-secondary text-white-primary text-sm font-semibold transition duration-200"
        >
          <i class="fas fa-sign-out-alt w-5"></i> <span>Keluar / Logout</span>
        </button>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex grow p-4 md:p-8 space-y-6">
      <main class="grow p-4 md:p-8">
        <div x-show="activeTab === 'overview'" x-transition>
          <%- include("./components/overview") %>
        </div>

        <div x-show="activeTab === 'users'" x-transition>
          <%- include("./components/data-pengguna") %>
        </div>

        <div x-show="activeTab === 'logs'" x-transition>
          <%- include("./components/log-aktivitas") %>
        </div>
      </main>
    </main>
  </div>

  <footer
    class="bg-black-secondary text-gray-primary text-center py-3 text-xs border-t border-black-accent"
  >
    &copy; 2026 Admin Panel — Crafted for Supervisor. All rights reserved.
  </footer>
</div>

<!-- 
navbar untuk user dan supervisor
      Parameter :
      responsivNav : 'left' || 'top'  2 pilihan , default top-->
<% const navType = typeof responsivNav !== 'undefined' ? responsivNav : 'top';
%>

<header
  x-data="navbarController()"
  x-init="init()"
  class="shadow-md transition-all duration-300 z-100 relative"
  :class="[
    navbarColor[currentPath] || 'bg-white-primary',
    responsivNav === 'left' ? 'md:fixed md:left-0 md:top-0 md:w-64 md:h-screen md:border-r md:border-neutral-800' : 'sticky top-0 w-full'
  ]"
>
  <div
    class="w-full transition-all duration-300"
    :class="responsivNav === 'left' 
      ? 'px-4 md:flex md:flex-col md:h-full' 
      : 'max-w-7xl mx-auto px-4 h-16 flex items-center justify-between'"
  >
    <div
      class="flex items-center justify-between w-full"
      :class="responsivNav === 'left' ? 'h-16 md:h-20 md:border-b border-neutral-700/30 md:mb-6 md:w-full' : 'h-16 md:w-auto'"
    >
      <a href="/" class="flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center shadow-md border border-neutral-700/20"
          :class="navbarColor[currentPath] || 'bg-white-primary'"
        >
          <span
            class="font-bold text-lg"
            :class="responsivNav === 'left' ? 'text-white' : 'text-dark'"
          >
            <i class="fa-sharp fa-solid fa-r"></i>
          </span>
        </div>
        <span
          class="text-xl font-bold"
          :class="responsivNav === 'left' ? 'text-white-primary md:block' : 'text-dark'"
          >Rant</span
        >
      </a>

      <button
        @click="mobileMenu = !mobileMenu"
        class="md:hidden p-2 rounded-lg hover:bg-neutral-200 transition"
        :class="responsivNav === 'left' ? 'text-white' : 'text-dark'"
      >
        <i class="fas fa-bars text-xl"></i>
      </button>
    </div>

    <nav
      class="hidden md:flex transition-all duration-300"
      :class="responsivNav === 'left' ? 'flex-col gap-2 w-full flex-1' : 'items-center gap-3'"
    >
      <template x-for="(item, index) in menuItems" :key="index">
        <a
          :href="item.url"
          class="rounded-xl transition font-medium flex items-center gap-3"
          :class="[
            responsivNav === 'left' ? 'px-4 py-3 w-full' : 'px-4 py-2.5',
            
            // Logika Pewarnaan Aktif vs Inaktif
            currentPath === item.url 
              ? (responsivNav === 'left' ? 'bg-main-primary text-white shadow-md' : 'bg-neutral-800 text-white shadow-md')
              : (item.isAccent 
                  ? 'bg-primary text-light hover:opacity-90 shadow-md' 
                  : (responsivNav === 'left' ? 'text-gray-accent hover:bg-neutral-800 hover:text-white' : 'text-dark hover:bg-gray-100'))
          ]"
        >
          <i :class="item.icon" class="w-5 text-center text-lg"></i>
          <span x-text="item.title"></span>
        </a>
      </template>
    </nav>
  </div>

  <div
    x-show="mobileMenu"
    @click.away="mobileMenu = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    x-cloak
    class="md:hidden absolute top-full left-0 w-full pb-5 pt-3 px-4 space-y-2 shadow-xl border-b border-neutral-700/10 z-[105]"
    :class="navbarColor[currentPath] || 'bg-white-primary'"
  >
    <template x-for="(item, index) in menuItems" :key="'mobile-'+index">
      <a
        :href="item.url"
        class="px-4 py-3 rounded-xl transition font-medium flex items-center gap-3 block w-full"
        :class="[
          currentPath === item.url 
            ? 'bg-main-primary text-white shadow-md'
            : (item.isAccent ? 'bg-primary text-light shadow-sm' : 'text-dark bg-gray-50 hover:bg-gray-100')
        ]"
      >
        <i :class="item.icon" class="w-5 text-center"></i>
        <span
          x-text="item.title === 'Profile' && username ? username : item.title"
        ></span>
      </a>
    </template>
  </div>
</header>

<script>
  function navbarController() {
    return {
      currentPath: window.location.pathname,
      mobileMenu: false,
      username:
        '<%= typeof currentUser !== "undefined" ? currentUser.username : "" %>',

      responsivNav: '<%= navType %>',

      navbarColor: {
        '/user/profile': 'bg-white-primary',
        '/forums': 'bg-main-primary',
        '/user': 'bg-main-white-primary',
        '/forums/search-chat': 'bg-black-secondary text-white-secondary',
        '/forums/chat': 'bg-gray-primary',
        '/forums/group/': 'bg-gray-secondary',
      },

      menuItems: [
        { title: 'Dashboard', url: '/', icon: 'fas fa-home', isAccent: false },
        {
          title: 'Forums',
          url: '/forums',
          icon: 'fas fa-comments',
          isAccent: false,
        },
        { title: 'User', url: '/user', icon: 'fas fa-users', isAccent: true },
        {
          title: 'Profile',
          url: '/user/profile',
          icon: 'fas fa-user-circle',
          isAccent: true,
        },
      ],

      init() {
        if (this.currentPath.includes('/supervisor')) {
          this.menuItems = [
            {
              title: 'Overview',
              url: '/supervisor',
              icon: 'fas fa-home',
              isAccent: false,
            },
            {
              title: 'Create User',
              url: '/supervisor/user/create',
              icon: 'fas fa-user-plus',
              isAccent: false,
            },
            {
              title: 'Data Pengguna',
              url: '/supervisor/users',
              icon: 'fas fa-users',
              isAccent: false,
            },
            {
              title: 'Log Aktivitas',
              url: '/supervisor/logs',
              icon: 'fas fa-history',
              isAccent: true,
            },
          ];
        }
      },
    };
  }
</script>

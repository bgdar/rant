<div class="bg-gray-100 min-h-screen">
  <!-- Navbar -->
  <header class="bg-light shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center shadow-md"
          >
            <span class="text-light font-bold text-lg"> R </span>
          </div>

          <span class="text-xl font-bold text-dark"> Rant </span>
        </a>

        <!-- Desktop Menu -->
        <nav class="hidden md:flex items-center gap-4">
          <a
            href="/"
            class="px-4 py-2 rounded-xl text-dark hover:bg-gray-100 transition font-medium"
          >
            Home
          </a>

          <a
            href="/forums"
            class="px-4 py-2 rounded-xl text-dark hover:bg-gray-100 transition font-medium"
          >
            Forums
          </a>

          <a
            href="/profile"
            class="px-4 py-2 rounded-xl bg-primary text-light hover:opacity-90 transition font-medium shadow-md"
          >
            Profile
          </a>
        </nav>

        <!-- Mobile Button -->
        <button
          @click="mobileMenu = !mobileMenu"
          class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition"
        >
          ☰
        </button>
      </div>

      <!-- Mobile Menu -->
      <div x-show="mobileMenu" x-transition class="md:hidden pb-4 space-y-2">
        <a
          href="/"
          class="block px-4 py-3 rounded-xl hover:bg-gray-100 transition font-medium"
        >
          Home
        </a>

        <a
          href="/forums"
          class="block px-4 py-3 rounded-xl hover:bg-gray-100 transition font-medium"
        >
          Forums
        </a>

        <a
          href="/profile"
          class="block px-4 py-3 rounded-xl bg-primary text-light transition font-medium"
        >
          Profile
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left -->
      <div>
        <span
          class="inline-block bg-primary/10 text-primary font-semibold px-4 py-2 rounded-full mb-6"
        >
          Welcome Back 👋
        </span>

        <h1 class="text-5xl font-bold text-dark leading-tight">
          Join The Best
          <span class="text-primary"> Discussion </span>
          Community
        </h1>

        <p class="text-graysoft text-lg mt-6 leading-relaxed">
          Share your thoughts, connect with people, and explore interesting
          discussions from around the world.
        </p>

        <div class="flex flex-wrap gap-4 mt-8">
          <a
            href="/forums"
            class="bg-primary text-light px-6 py-3 rounded-2xl font-semibold shadow-lg hover:opacity-90 transition"
          >
            Explore Forums
          </a>

          <a
            href="/profile"
            class="border border-gray-300 px-6 py-3 rounded-2xl font-semibold hover:bg-gray-100 transition"
          >
            My Profile
          </a>
        </div>
      </div>

      <!-- Right -->
      <div class="relative">
        <div class="bg-light rounded-3xl shadow-2xl p-8 border border-gray-200">
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-14 h-14 rounded-2xl bg-primary flex items-center justify-center"
            >
              <span class="text-light text-xl font-bold"> Z </span>
            </div>

            <div>
              <h3 class="font-bold text-dark text-lg">Zero</h3>

              <p class="text-graysoft text-sm">Full Stack Developer</p>
            </div>
          </div>

          <div class="space-y-4">
            <div class="bg-gray-100 rounded-2xl p-4">
              <h4 class="font-semibold text-dark mb-2">Latest Discussion</h4>

              <p class="text-graysoft text-sm">
                "What is your favorite backend framework in 2026?"
              </p>
            </div>

            <div class="bg-gray-100 rounded-2xl p-4">
              <h4 class="font-semibold text-dark mb-2">Trending Topic</h4>

              <p class="text-graysoft text-sm">
                NestJS + Fastify performance discussion is trending now.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Section -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <div class="grid md:grid-cols-3 gap-6">
      <!-- Card -->
      <div class="bg-light p-6 rounded-3xl shadow-lg border border-gray-200">
        <div
          class="w-14 h-14 bg-primary rounded-2xl flex items-center justify-center text-light text-2xl mb-5"
        >
          💬
        </div>

        <h3 class="text-xl font-bold text-dark mb-3">Active Discussions</h3>

        <p class="text-graysoft leading-relaxed">
          Participate in thousands of community discussions every day.
        </p>
      </div>

      <!-- Card -->
      <div class="bg-light p-6 rounded-3xl shadow-lg border border-gray-200">
        <div
          class="w-14 h-14 bg-primary rounded-2xl flex items-center justify-center text-light text-2xl mb-5"
        >
          👥
        </div>

        <h3 class="text-xl font-bold text-dark mb-3">Friendly Community</h3>

        <p class="text-graysoft leading-relaxed">
          Meet developers, designers, and creators from around the world.
        </p>
      </div>

      <!-- Card -->
      <div class="bg-light p-6 rounded-3xl shadow-lg border border-gray-200">
        <div
          class="w-14 h-14 bg-primary rounded-2xl flex items-center justify-center text-light text-2xl mb-5"
        >
          🚀
        </div>

        <h3 class="text-xl font-bold text-dark mb-3">Share Your Ideas</h3>

        <p class="text-graysoft leading-relaxed">
          Create posts, ask questions, and build your audience easily.
        </p>
      </div>
    </div>
  </section>
</div>

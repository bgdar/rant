<div
  class="bg-white-secondary min-h-screen font-sans selection:bg-main-muted selection:text-main-primary"
  x-data="{
    username: '<%= username %>',
  }"
>
  <%- include('../components/navbar') %>

  <main
    class="max-w-5xl mx-auto px-6 py-20 flex flex-col items-center justify-center text-center"
  >
    <section class="max-w-3xl flex flex-col items-center mb-24 animate-fade-in">
      <span
        class="inline-flex items-center gap-2 bg-main-muted text-main-secondary font-medium text-xs tracking-wider uppercase px-4 py-1.5 rounded-full border border-main-accent/20 mb-8"
      >
        <i class="fa-solid fa-circle-check text-[10px] animate-pulse"></i>
        Welcome Back
      </span>

      <h1
        class="text-4xl md:text-6xl font-black text-black-primary tracking-tight leading-none mb-6"
      >
        Hello, <span class="text-main-primary" x-text="username"></span>
      </h1>

      <p
        class="text-black-muted text-base md:text-xl max-w-xl font-normal leading-relaxed mb-10"
      >
        Share your thoughts, connect with people, and explore interesting
        discussions from around the world.
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center"
      >
        <a
          href="/forums"
          class="inline-flex items-center justify-center gap-2 bg-main-primary text-white-primary px-8 py-3.5 rounded-xl font-semibold shadow-md shadow-main-primary/20 hover:bg-main-secondary active:scale-[0.98] transition-all duration-200 group"
        >
          <i
            class="fa-solid fa-comments text-white-muted/80 group-hover:translate-x-0.5 transition-transform"
          ></i>
          Explore Forums
        </a>

        <a
          href="/user/profile"
          class="inline-flex items-center justify-center gap-2 bg-white-primary border border-white-muted text-black-secondary px-8 py-3.5 rounded-xl font-semibold hover:bg-white-accent hover:border-gray-primary/30 active:scale-[0.98] transition-all duration-200"
        >
          <i class="fa-solid fa-user-gear text-gray-primary"></i>
          <p x-text="username"></p>
        </a>
      </div>
    </section>

    <section class="w-full space-y-16">
      <div
        class="max-w-2xl mx-auto bg-white-primary rounded-2xl border border-white-accent p-6 md:p-8 shadow-sm"
      >
        <div
          class="flex flex-col sm:flex-row items-center sm:text-left gap-4 pb-6 mb-6 border-b border-white-accent"
        >
          <div
            class="w-14 h-14 rounded-xl bg-black-primary text-white-primary flex items-center justify-center shadow-inner font-bold text-xl uppercase tracking-wider"
            x-text="username.charAt(0)"
          ></div>
          <div class="flex-1">
            <h3
              class="font-bold text-black-secondary text-lg"
              x-text="username"
            ></h3>
            <p
              class="text-gray-secondary text-xs font-medium uppercase tracking-wide flex items-center justify-center sm:justify-start gap-1.5 mt-0.5"
            >
              <i class="fa-solid fa-shield-halved text-main-primary"></i>
              Community Member
            </p>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 text-left">
          <div
            class="bg-white-secondary rounded-xl p-4 border border-white-accent/60 group hover:border-main-accent/30 transition-all"
          >
            <span
              class="text-xs font-bold text-main-secondary uppercase tracking-wider block mb-1"
            >
              <i class="fa-solid fa-fire-flame-curved mr-1"></i> Latest
              Discussion
            </span>
            <p
              class="text-black-accent text-sm font-medium leading-normal line-clamp-2"
            >
              "What is your favorite backend framework in 2026?"
            </p>
          </div>

          <div
            class="bg-white-secondary rounded-xl p-4 border border-white-accent/60 group hover:border-main-accent/30 transition-all"
          >
            <span
              class="text-xs font-bold text-black-muted uppercase tracking-wider block mb-1"
            >
              <i class="fa-solid fa-chart-line mr-1"></i> Trending Topic
            </span>
            <p
              class="text-black-accent text-sm font-medium leading-normal line-clamp-2"
            >
              NestJS + Fastify performance discussion is trending now.
            </p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 text-left pt-6">
        <div
          class="bg-white-primary p-6 rounded-2xl border border-white-accent hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
        >
          <div>
            <div
              class="w-12 h-12 bg-main-muted text-main-primary rounded-xl flex items-center justify-center text-lg mb-5"
            >
              <i class="fa-solid fa-comments"></i>
            </div>
            <h3 class="text-lg font-bold text-black-secondary mb-2">
              Active Discussions
            </h3>
            <p class="text-black-muted text-sm leading-relaxed">
              Participate in thousands of community discussions every day.
            </p>
          </div>
        </div>

        <div
          class="bg-white-primary p-6 rounded-2xl border border-white-accent hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
        >
          <div>
            <div
              class="w-12 h-12 bg-black-primary text-white-primary rounded-xl flex items-center justify-center text-lg mb-5"
            >
              <i class="fa-solid fa-users"></i>
            </div>
            <h3 class="text-lg font-bold text-black-secondary mb-2">
              Friendly Community
            </h3>
            <p class="text-black-muted text-sm leading-relaxed">
              Meet developers, designers, and creators from around the world.
            </p>
          </div>
        </div>

        <div
          class="bg-white-primary p-6 rounded-2xl border border-white-accent hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
        >
          <div>
            <div
              class="w-12 h-12 bg-white-secondary text-black-secondary border border-white-muted rounded-xl flex items-center justify-center text-lg mb-5"
            >
              <i class="fa-solid fa-rocket text-main-primary"></i>
            </div>
            <h3 class="text-lg font-bold text-black-secondary mb-2">
              Share Your Ideas
            </h3>
            <p class="text-black-muted text-sm leading-relaxed">
              Create posts, ask questions, and build your audience easily.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>

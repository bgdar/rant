<div
  x-data="signUpHandler()"
  class="bg-light min-h-screen flex items-center justify-center px-4 py-10"
>
  <div class="w-full max-w-lg">
    <div class="bg-light border border-gray-200 rounded-3xl shadow-2xl p-8">
      <div class="flex justify-center mb-8">
        <div
          class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center shadow-lg"
        >
          <span class="text-light text-2xl font-bold"> R </span>
        </div>
      </div>

      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-dark">Create Account</h1>

        <p class="text-graysoft mt-2">Register and start your journey</p>
      </div>

      <!-- nantik pindahin ke global layout-->
      <div
        x-show="alert.show"
        x-transition
        x-text="alert.message"
        :class="alert.type === 'success'
          ? 'bg-green-100 text-green-700 border-green-300'
          : 'bg-red-100 text-red-700 border-red-300'"
        class="mb-5 px-4 py-3 rounded-xl text-sm font-medium border"
      ></div>

      <form class="space-y-5" @submit.prevent="submitRegister">
        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Full Name
          </label>

          <input
            type="text"
            x-model="form.fullName"
            placeholder="John Doe"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
          />
        </div>

        <!-- Username -->
        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Username
          </label>

          <input
            type="text"
            x-model="form.username"
            placeholder="@username"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
          />
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Email Address
          </label>

          <input
            type="email"
            x-model="form.email"
            placeholder="example@email.com"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
          />
        </div>

        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Password
          </label>

          <div class="relative">
            <input
              :type="showPassword ? 'text' : 'password'"
              x-model="form.password"
              placeholder="Create password"
              required
              class="w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
            />

            <button
              type="button"
              @click="showPassword = !showPassword"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-graysoft hover:text-dark transition"
            >
              <span x-show="!showPassword"> 👁️ </span>

              <span x-show="showPassword"> 🙈 </span>
            </button>
          </div>
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Confirm Password
          </label>

          <div class="relative">
            <input
              :type="showConfirmPassword
                ? 'text'
                : 'password'"
              x-model="form.confirmPassword"
              placeholder="Confirm password"
              required
              class="w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
            />

            <button
              type="button"
              @click="showConfirmPassword = !showConfirmPassword"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-graysoft hover:text-dark transition"
            >
              <span x-show="!showConfirmPassword"> 👁️ </span>

              <span x-show="showConfirmPassword"> 🙈 </span>
            </button>
          </div>
        </div>

        <label class="flex items-start gap-3 cursor-pointer">
          <input
            type="checkbox"
            x-model="form.acceptTerms"
            required
            class="accent-primary w-4 h-4 mt-1"
          />

          <span class="text-sm text-graysoft leading-relaxed">
            I agree to the

            <a href="#" class="text-primary font-medium hover:underline">
              Terms & Conditions
            </a>

            and

            <a href="#" class="text-primary font-medium hover:underline">
              Privacy Policy
            </a>
          </span>
        </label>

        <button
          type="submit"
          :disabled="loading"
          class="w-full bg-primary hover:opacity-90 text-light font-semibold py-3 rounded-xl transition duration-300 shadow-lg disabled:opacity-50"
        >
          <span x-show="!loading"> Create Account </span>

          <span x-show="loading"> Loading... </span>
        </button>
      </form>

      <!-- Divider -->
      <div class="flex items-center gap-4 my-8">
        <div class="flex-1 h-px bg-gray-200"></div>

        <span class="text-graysoft text-sm"> OR </span>

        <div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <!-- Social -->
      <div class="grid grid-cols-2 gap-4">
        <button
          class="border border-gray-300 py-3 rounded-xl font-medium hover:bg-gray-100 transition"
        >
          Google
        </button>

        <button
          class="border border-gray-300 py-3 rounded-xl font-medium hover:bg-gray-100 transition"
        >
          GitHub
        </button>
      </div>

      <!-- Footer -->
      <p class="text-center text-graysoft text-sm mt-8">
        Already have an account?

        <!-- url sekarang + /singIn -->
        <a href="/signIn" class="text-primary font-semibold hover:underline">
          Sign In
        </a>
      </p>
    </div>
  </div>
</div>

<script>
  function signUpHandler() {
    return {
      loading: false,

      showPassword: false,

      showConfirmPassword: false,

      form: {
        fullName: '',
        username: '',
        email: '',
        password: '',
        confirmPassword: '',
        acceptTerms: false,
      },

      alert: {
        show: false,
        type: 'error',
        // masuk dari JSOSN Server
        message: '',
      },

      setAlert(message, type = 'error') {
        this.alert.show = true;

        this.alert.message = message;

        this.alert.type = type;
      },

      validateForm() {
        if (this.form.password !== this.form.confirmPassword) {
          this.setAlert('Password confirmation does not match');

          return false;
        }

        if (this.form.password.length < 6) {
          this.setAlert('Password minimum 6 characters');

          return false;
        }

        if (!this.form.acceptTerms) {
          this.setAlert('Please accept terms and conditions');

          return false;
        }

        return true;
      },

      async submitRegister() {
        if (!this.validateForm()) {
          return;
        }

        try {
          this.loading = true;

          const req = await fetch('/user/signUp', {
            method: 'POST',

            headers: {
              'Content-Type': 'application/json',
            },

            body: JSON.stringify(this.form),
          });

          const res = await req.json();

          if (!req.ok) {
            return this.setAlert(res.message || 'Register failed');
          }

          this.setAlert(res.message || 'Register success', 'success');

          this.form = {
            fullName: '',
            username: '',
            email: '',
            password: '',
            confirmPassword: '',
            acceptTerms: false,
          };

          // jangan pindah manual
          //setTimeout(() => {
          //window.location.href = '/';
          // }, 1200);
        } catch (error) {
          console.error(error);

          this.setAlert('Server error, please try again');
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>

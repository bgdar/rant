<div
  x-data="signInHandler()"
  class="bg-light min-h-screen flex items-center justify-center px-4"
>
  <div class="w-full max-w-md">
    <!-- Card -->
    <div class="bg-light border border-gray-200 rounded-3xl shadow-2xl p-8">
      <!-- Logo -->
      <div class="flex justify-center mb-8">
        <div
          class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center shadow-lg"
        >
          <span class="text-light text-2xl font-bold"> R </span>
        </div>
      </div>

      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-dark">Welcome Back</h1>

        <p class="text-graysoft mt-2">Sign in to continue your account</p>
      </div>

      <div
        x-show="alert.show"
        x-transition
        x-text="alert.message"
        :class="alert.type === 'success'
          ? 'bg-green-100 text-green-700 border-green-300'
          : 'bg-red-100 text-red-700 border-red-300'"
        class="mb-5 px-4 py-3 rounded-xl text-sm font-medium border"
      ></div>

      <form class="space-y-5" @submit.prevent="submitLogin">
        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            email
          </label>

          <input
            type="text"
            x-model="form.email"
            placeholder="your email account"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
          />
        </div>

        <div>
          <label class="block text-sm font-semibold text-dark mb-2">
            Password
          </label>

          <div class="relative">
            <input
              :type="showPassword ? 'text' : 'password'"
              x-model="form.password"
              placeholder="Enter your password"
              required
              class="w-full px-4 py-3 pr-14 rounded-xl border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition"
            />

            <button
              type="button"
              @click="showPassword = !showPassword"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-graysoft hover:text-dark transition"
            >
              <span x-show="!showPassword"> 👁️ </span>

              <span x-show="showPassword"> 🙈 </span>
            </button>
          </div>
        </div>

        <div class="flex items-center justify-between text-sm">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" class="accent-primary w-4 h-4" />

            <span class="text-graysoft"> Remember me </span>
          </label>

          <a
            href="/forgot-password"
            class="text-primary font-medium hover:underline"
          >
            Forgot Password?
          </a>
        </div>

        <button
          type="submit"
          :disabled="loading"
          class="w-full bg-primary hover:opacity-90 text-light font-semibold py-3 rounded-xl transition duration-300 shadow-lg disabled:opacity-50"
        >
          <span x-show="!loading"> Sign In </span>

          <span x-show="loading"> Loading... </span>
        </button>
      </form>

      <div class="flex items-center gap-4 my-8">
        <div class="flex-1 h-px bg-gray-200"></div>

        <span class="text-graysoft text-sm"> OR </span>

        <div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <!-- OAuth -->
      <div class="grid grid-cols-2 gap-4">
        <button
          class="border border-gray-300 py-3 rounded-xl font-medium hover:bg-gray-100 transition"
        >
          Google
        </button>
      </div>

      <p class="text-center text-graysoft text-sm mt-8">
        Don’t have an account?

        <a
          href="/user/signUp"
          class="text-primary font-semibold hover:underline"
        >
          Sign Up
        </a>
      </p>
    </div>
  </div>
</div>

<script>
  function signInHandler() {
    return {
      loading: false,

      showPassword: false,

      form: {
        email: '',
        password: '',
      },

      alert: {
        show: false,
        type: 'error',
        message: '',
      },

      setAlert(message, type = 'error') {
        this.alert.show = true;
        this.alert.message = message;
        this.alert.type = type;
      },

      async submitLogin() {
        try {
          this.loading = true;

          const req = await fetch('/user/signIn', {
            method: 'POST',

            headers: {
              'Content-Type': 'application/json',
            },

            body: JSON.stringify(this.form),
          });

          const res = await req.json();

          if (!req.ok) {
            return this.setAlert(res.message || 'Login failed');
          }

          this.setAlert(res.message || 'Login success', 'success');

          setTimeout(() => {
            window.location.href = '/user';
          }, 1300);
        } catch (error) {
          console.error(error);

          this.setAlert('Server error, please try again');
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>

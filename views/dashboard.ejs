<!--  include("layouts")  ini tidak perlu lagi , karen otomatis dari fastify + ejs -->
<div class="bg-[#FFFFFF] text-[#000000] font-sans">
  <section
    class="relative h-screen flex items-center justify-center bg-fixed-custom"
  >
    <div class="absolute inset-0 bg-blue-900/40 backdrop-blur-[2px]"></div>

    <div
      class="relative z-10 text-center px-4"
      x-data="{ show: false }"
      x-init="setTimeout(() => show = true, 100)"
    >
      <h1
        x-show="show"
        x-transition:enter="transition ease-out duration-1000"
        x-transition:enter-start="opacity-0 transform translate-y-10"
        x-transition:enter-end="opacity-100 transform translate-y-0"
        class="text-5xl md:text-7xl font-bold text-[#FFFFFF] mb-6 tracking-tight"
      >
        Eksplorasi <span class="text-[#FF0000]">Inovasi</span>
      </h1>

      <p
        x-show="show"
        x-transition:enter="transition ease-out duration-1000 delay-300"
        class="text-[#FFFFFF] text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed"
      >
        Platform modern yang menggabungkan kecepatan teknologi dengan estetika
        desain minimalis untuk pengalaman pengguna terbaik.
      </p>

      <div
        x-show="show"
        x-transition:enter="transition ease-out duration-1000 delay-500"
      >
        <a
          href="/rant"
          class="bg-main hover:bg-red-700 text-[#FFFFFF] font-bold py-4 px-10 rounded-full transition duration-300 shadow-lg inline-block"
        >
          Rant
        </a>

        <a
          href="/user"
          class="bg-blackmain hover:bg-red-700 text-[#FFFFFF] font-bold py-4 px-10 rounded-full transition duration-300 shadow-lg inline-block"
        >
          Your
        </a>
      </div>
    </div>
  </section>

  <section id="info" class="py-20 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-[#000000] mb-4">Informasi Layanan</h2>
      <div class="w-20 h-1 bg-[#FF0000] mx-auto"></div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-8"
      x-data="{ selected: null }"
    >
      <div
        @mouseenter="selected = 1"
        @mouseleave="selected = null"
        class="p-8 border border-[#999999]/20 rounded-xl transition-all duration-300 hover:shadow-2xl bg-[#FFFFFF]"
        :class="selected === 1 ? 'border-[#FF0000] -translate-y-2' : ''"
      >
        <div
          class="w-12 h-12 bg-[#FF0000] flex items-center justify-center rounded-lg mb-6"
        >
          <svg
            class="w-6 h-6 text-[#FFFFFF]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[#000000]">Performa Cepat</h3>
        <p class="text-[#999999]">
          Dibangun dengan teknologi terbaru untuk memastikan akses tanpa
          hambatan di semua perangkat.
        </p>
      </div>

      <div
        @mouseenter="selected = 2"
        @mouseleave="selected = null"
        class="p-8 border border-[#999999]/20 rounded-xl transition-all duration-300 hover:shadow-2xl bg-[#FFFFFF]"
        :class="selected === 2 ? 'border-[#FF0000] -translate-y-2' : ''"
      >
        <div
          class="w-12 h-12 bg-[#000000] flex items-center justify-center rounded-lg mb-6"
        >
          <svg
            class="w-6 h-6 text-[#FFFFFF]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[#000000]">Keamanan Data</h3>
        <p class="text-[#999999]">
          Privasi Anda adalah prioritas kami. Enkripsi tingkat tinggi di setiap
          lapisan data.
        </p>
      </div>

      <div
        @mouseenter="selected = 3"
        @mouseleave="selected = null"
        class="p-8 border border-[#999999]/20 rounded-xl transition-all duration-300 hover:shadow-2xl bg-[#FFFFFF]"
        :class="selected === 3 ? 'border-[#FF0000] -translate-y-2' : ''"
      >
        <div
          class="w-12 h-12 bg-[#999999] flex items-center justify-center rounded-lg mb-6"
        >
          <svg
            class="w-6 h-6 text-[#FFFFFF]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[#000000]">Desain Adaptif</h3>
        <p class="text-[#999999]">
          Antarmuka yang menyesuaikan dengan kebutuhan visual Anda, bersih dan
          fungsional.
        </p>
      </div>
    </div>
  </section>

  <footer class="bg-[#000000] py-10 text-center">
    <p class="text-[#999999] text-sm">
      &copy; 2026 Brand Anda. All rights reserved.
    </p>
  </footer>
  >
</div>
